# =============================================================================
# ELYSIAN HAIR SPA — .gitignore
# =============================================================================

# =============================================================================
# DJANGO (backend/)
# =============================================================================
backend/venv/
backend/.env
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/db.sqlite3
backend/staticfiles/
backend/mediafiles/
backend/*.log

# =============================================================================
# NEXT.JS (frontend/)
# =============================================================================
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/

# =============================================================================
# GENERAL
# =============================================================================

# OS
.DS_Store
Thumbs.db

# IDEs & Editors
.vscode/
.idea/
*.swp
*.swo

.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*